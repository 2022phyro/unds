generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String                 @id @default(cuid())
  email        String                 @unique
  passwordHash String?
  role         Role                   @default(USER)
  isStaff      Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  department   String?
  faculty      String?
  firstName    String?
  lastName     String?
  level        String?
  phone        String?
  application  MembershipApplication?
  memberships  UserToGroup[]
}

model MembershipApplication {
  id         String   @id @default(cuid())
  userId     String   @unique
  receiptUrl String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id      String        @id @default(cuid())
  name    String        @unique
  members UserToGroup[]
}

model UserToGroup {
  userId  String
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Album {
  id               String        @id @default(cuid())
  slug             String        @unique
  category         AlbumCategory
  year             Int
  title            String
  subtitle         String
  dateString       String
  location         String
  imageUrl         String
  institutions     String[]      @default([])
  cloudinaryFolder String        @unique
  photoCount       Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TournamentConfig {
  id                         String                      @id @default(cuid())
  slug                       String                      @unique
  type                       EventType
  status                     EventStatus
  statusText                 String
  scopeText                  String
  title                      String
  description                String
  debateFormat               String
  deliveryMode               DeliveryMode                @default(OFFLINE)
  location                   String
  dateString                 String
  sortDate                   DateTime
  deadlineText               String?
  registrationUrl            String?
  registrationType           RegistrationType            @default(NONE)
  adjudicatorPolicy          AdjudicatorPolicy           @default(NONE)
  fixedAdjudicatorCount      Int?
  whoShouldAttend            String[]                    @default([])
  schedule                   Json
  faqs                       Json
  isFeatured                 Boolean                     @default(false)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  includesPS                 Boolean                     @default(false)
  psAdjudicatorsAllowed      Boolean                     @default(false)
  adjudicatorRegistrations   AdjudicatorRegistration[]
  individualRegistrations    IndividualRegistration[]
  psAdjudicatorRegistrations PSAdjudicatorRegistration[]
  psRegistrations            PSRegistration[]
  teamRegistrations          TeamRegistration[]
}

model TeamRegistration {
  id           String           @id @default(cuid())
  tournamentId String
  institution  String
  teamName     String
  player1Name  String
  player1Email String
  player2Name  String
  player2Email String
  createdAt    DateTime         @default(now())
  adjEmail     String?
  adjName      String?
  tournament   TournamentConfig @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamName])
}

model AdjudicatorRegistration {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  email        String
  createdAt    DateTime         @default(now())
  tournament   TournamentConfig @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, email])
}

model IndividualRegistration {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  email        String
  createdAt    DateTime         @default(now())
  tournament   TournamentConfig @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, email])
}

model PSRegistration {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  email        String
  institution  String
  createdAt    DateTime         @default(now())
  tournament   TournamentConfig @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, email])
}

model PSAdjudicatorRegistration {
  id           String           @id @default(cuid())
  tournamentId String
  name         String
  email        String
  createdAt    DateTime         @default(now())
  tournament   TournamentConfig @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

enum AlbumCategory {
  TOURNAMENTS
  TRAININGS
  SOCIALS
  AWARDS
}

enum EventType {
  INTERNAL_HOST
  EXTERNAL_MAJOR
  RECURRING_LOOP
}

enum EventStatus {
  REGISTRATION_OPEN
  REGISTRATION_LOCKED
  COMPLETED
  ONGOING
  CLOSING_SOON
}

enum DeliveryMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum RegistrationType {
  NONE
  INDIVIDUAL
  TEAM
}

enum AdjudicatorPolicy {
  N_PLUS_ONE
  FIXED
  NONE
}
